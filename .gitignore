# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
functions/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# firebase
.firebase
firebase-debug.log*
.runtimeconfig.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local dev data
/data

# render executor artifacts
/executors/render-executor/artifacts/

# blog worker
executors/naver-blog-worker/node_modules/
executors/naver-blog-worker/.session/
tmp/

# blog_publisher (Python 파이프라인) — 런타임 산출물/비밀은 커밋 제외
blog_publisher/**/__pycache__/
blog_publisher/**/*.pyc
blog_publisher/db/blog.db
blog_publisher/db/blog.db-shm
blog_publisher/db/blog.db-wal
blog_publisher/db/generate.lock
blog_publisher/db/publish.lock
blog_publisher/db/.fuse_hidden*
blog_publisher/db/backups/
**/*.tmp

bin/
logs/

# BEOK лё”лЎңк·ё мһҗлҸҷнҷ” crontab м°ёкі  мҳҲмӢң
#
# мЈј мҡҙмҳҒ кІҪлЎңлҠ” macOS LaunchAgentмһ…лӢҲлӢӨ:
#   bash blog_publisher/ops/install-ops.sh
#
# мқҙ нҢҢмқјмқҖ LaunchAgentлҘј м“ё мҲҳ м—ҶлҠ” нҷҳкІҪмқҳ л°ұм—…мҡ©мһ…лӢҲлӢӨ.
# macOSм—җм„ң crontab м Ғмҡ©мқҙ л°ҳнҷҳлҗҳм§Җ м•ҠлҠ” кІҪмҡ°к°Җ мһҲм–ҙ кё°ліё мҡҙмҳҒм—җлҠ” к¶ҢмһҘн•ҳм§Җ м•ҠмҠөлӢҲлӢӨ.
# м„Өм№ҳ:  crontab blog_publisher/ops/crontab.example
# нҷ•мқё:  crontab -l
#
# кІҪлЎң/л°”мқҙл„ҲлҰ¬лҠ” нҷҳкІҪм—җ л§һкІҢ нҷ•мқё:
#   which python3   # мқҙ л§ҘмқҖ /usr/bin/python3м—җ н•„мҡ”н•ң нҢЁнӮӨм§Җк°Җ м„Өм№ҳлҗҳм–ҙ мһҲмқҢ
#   which node
# м•„лһҳлҠ” Apple Silicon(homebrew) кё°мӨҖ. лЎңк·ёлҠ” newsyslogлЎң нҡҢм „(ops/newsyslog-blog.conf).

PYTHON=/usr/bin/python3
PUBDIR=/Users/aaron/Developer/personal/beokmkt/blog_publisher
WORKERDIR=/Users/aaron/Developer/personal/beokmkt/executors/naver-blog-worker

# в”Җв”Җ мҪҳн…җмё  нҢҢмқҙн”„лқјмқё в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# мҡҙмҳҒ мұ„л„җ: selfhosted + tistory. naver мһҗлҸҷ л°ңн–ү/мӢңл“ңлҠ” мӨ‘м§Җ.
# 0 */6 * * * cd $PUBDIR && $PYTHON run.py stock_seed selfhosted 15 >> /tmp/blog-generate.log 2>&1
# */30 * * * * cd $PUBDIR && $PYTHON run.py generate   >> /tmp/blog-generate.log 2>&1
# */15 * * * * cd $PUBDIR && $PYTHON run.py factcheck   >> /tmp/blog-factcheck.log 2>&1
# */30 * * * * cd $PUBDIR && $PYTHON run.py review      >> /tmp/blog-review.log 2>&1
# */30 * * * * cd $PUBDIR && $PYTHON run.py schedule    >> /tmp/blog-schedule.log 2>&1
# */5  * * * * cd $PUBDIR && $PYTHON run.py publish     >> /tmp/blog-publish.log 2>&1
# */5  * * * * cd $PUBDIR && $PYTHON run.py sync_snapshot >> /tmp/blog-publish.log 2>&1
# 17  * * * * cd $PUBDIR && $PYTHON run.py verify_public 20 >> /tmp/blog-verify.log 2>&1
# 23  */6 * * * cd $PUBDIR && $PYTHON run.py quality_selftest >> /tmp/blog-quality.log 2>&1
# 41  5 * * * cd $PUBDIR && $PYTHON run.py image_audit >> /tmp/blog-quality.log 2>&1

# в”Җв”Җ ліөкө¬ / мһ¬кі  / л°ұм—… в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# */35 * * * * cd $PUBDIR && $PYTHON run.py recover     >> /tmp/blog-recover.log 2>&1
# tistoryлҠ” н’Ҳм§Ҳ/мӨ‘ліө нҷ•мқё нӣ„ мҲҳлҸҷ seed вҶ’ generate/factcheck/review/schedule/publish кІҪлЎңлЎң мҡҙмҳҒ
# 0    6 * * * cd $PUBDIR && $PYTHON run.py auto_seed tistory 1    >> /tmp/blog-generate.log 2>&1
# 0    4 * * * cd $PUBDIR && $PYTHON run.py backup      >> /tmp/blog-backup.log 2>&1

# в”Җв”Җ м„ём…ҳ keepalive (л§Өмқј 10мӢң + м§Җн„°) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
0   10 * * * $PYTHON -c "import random,time; time.sleep(random.randint(0,1800))" && cd $WORKERDIR && /opt/homebrew/bin/npm run keepalive >> /tmp/blog-keepalive.log 2>&1

# в”Җв”Җ мӣҢм»ӨлҠ” LaunchAgent(com.beok.blog-worker.plist)к°Җ мғҒмӢң кө¬лҸҷ/мһ¬кё°лҸҷ в”Җв”Җ
# (@reboot л°ұм—…: LaunchAgent лҜём„Өм№ҳ мӢңм—җл§Ң мӮ¬мҡ©)
# @reboot cd $WORKERDIR && /opt/homebrew/bin/node index.mjs >> /tmp/blog-worker.log 2>&1

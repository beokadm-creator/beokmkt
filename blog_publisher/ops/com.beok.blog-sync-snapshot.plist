<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.beok.blog-sync-snapshot</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>run.py</string>
    <string>sync_snapshot</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/aaron/Developer/personal/beokmkt/blog_publisher</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>StandardOutPath</key>
  <string>/tmp/blog-publish.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/blog-publish.err.log</string>
</dict>
</plist>

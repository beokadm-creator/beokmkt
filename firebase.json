{
  "functions": [
    {
      "source": "functions",
      "runtime": "nodejs22"
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/sitemap.xml", "function": "api" },
      { "source": "/api/**", "function": "api" },
      { "source": "/blog", "function": "api" },
      { "source": "/blog/**", "function": "api" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}

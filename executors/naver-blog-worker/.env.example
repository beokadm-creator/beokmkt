# 워커 HTTP 서버 포트 (SPA가 이 주소로 발행 요청)
WORKER_PORT="8788"

# 메인 서버 (발행 결과 보고)
MAIN_API_URL="http://localhost:8787"
MAIN_API_TOKEN=""

# ─── 네이버 블로그 (Playwright 자동화) ──────────────────────────
NAVER_BLOG_USERNAME=""
NAVER_BLOG_ID=""
NAVER_BLOG_HEADLESS="true"
NAVER_BLOG_SLOW_MO="0"
NAVER_BLOG_TIMEOUT_MS="60000"
NAVER_BLOG_STORAGE_STATE_PATH="./.session/naver-session.json"

# ─── 티스토리 (공식 OAuth API) ─────────────────────────────────
# 1) https://www.tistory.com/guide/api/manage/register 에서 앱 등록
#    - Redirect URI: http://localhost:7878/callback (또는 원하는 값)
# 2) 아래 client_id/secret/blogName 입력
# 3) `npm run tistory-auth` 실행 → 브라우저 로그인 → access_token 자동 저장
TISTORY_CLIENT_ID=""
TISTORY_CLIENT_SECRET=""
TISTORY_REDIRECT_URI="http://localhost:7878/callback"
TISTORY_BLOG_NAME=""
# 이미 발급받은 토큰이 있으면 직접 입력
TISTORY_ACCESS_TOKEN=""
TISTORY_TOKEN_PATH="./.session/tistory-token.json"

# ─── 채널별 재작성/티스토리 디자인 ─────────────────────────────
CHANNEL_REWRITE="true"
AI_REWRITE_TIMEOUT_MS="120000"
AI_REWRITE_MAX_TOKENS="4096"
AI_REWRITE_THINKING="false"
TISTORY_AI_DESIGN="false"
TISTORY_AI_THINKING="false"
